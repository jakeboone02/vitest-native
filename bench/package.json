{
  "name": "vitest-native-bench",
  "private": true,
  "version": "0.0.0",
  "description": "Head-to-head benchmark: jest (RN preset) vs vitest-native (native + mock engines), same suite.",
  "type": "module",
  "scripts": {
    "bench": "node run.mjs",
    "jest": "jest --config jest.config.cjs",
    "vitest:native": "vitest run --config vitest.native.mts",
    "vitest:mock": "vitest run --config vitest.mock.mts"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@react-native/babel-preset": "0.85.3",
    "@testing-library/react-native": "12.9.0",
    "@vitest/coverage-v8": "4.0.18",
    "babel-jest": "29.7.0",
    "jest": "29.7.0",
    "jest-environment-node": "29.7.0",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-test-renderer": "19.2.4",
    "vite": "6.4.1",
    "vitest": "4.0.18",
    "vitest-native": "file:../packages/vitest-native"
  }
}
